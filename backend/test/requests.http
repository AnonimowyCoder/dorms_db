@baseUrl = http://localhost:3001
@json = Content-Type: application/json

###
# Health check
GET {{baseUrl}}

###
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "password123"
}

###

###
# Get current authenticated user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# USERS
# Admin only
# =========================

###
# Get all users
GET {{baseUrl}}/users
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one user
GET {{baseUrl}}/users/2
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create user
POST {{baseUrl}}/users
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "email": "manager1@example.com",
  "password": "password123",
  "role": "manager"
}

###
# Update user
PATCH {{baseUrl}}/users/3
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "email": "manager1@example.com",
  "role": "manager"
}

###
# Delete user
DELETE {{baseUrl}}/users/2
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# RESIDENTS
# Admin or Manager
# =========================

###
# Get all residents
GET {{baseUrl}}/residents
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one resident
GET {{baseUrl}}/residents/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create resident
POST {{baseUrl}}/residents
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "first_name": "Json",
  "last_name": "Therulo",
  "department": "Nuclear Physics"
}

###
# Update resident
PATCH {{baseUrl}}/residents/1
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "department": "science"
}

###
# Delete resident
DELETE {{baseUrl}}/residents/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# ROOMS
# Admin or Manager
# =========================

###
# Get all rooms
GET {{baseUrl}}/rooms
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get available rooms
GET {{baseUrl}}/rooms/available
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one room
GET {{baseUrl}}/rooms/2
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create room
POST {{baseUrl}}/rooms
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "room_number": 101,
  "floor_number": 1,
  "num_of_beds": 2,
  "id_category": 2
}

###
# Update room
PATCH {{baseUrl}}/rooms/1
Authorization: Bearer {{login.response.body.$.access_token}}
{{json}}

{
  "num_of_beds": 3
}

###
# Delete room
DELETE {{baseUrl}}/rooms/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# ROOM CATEGORIES
# Read: admin or manager
# Write: admin only
# =========================

###
# Get all room categories
GET {{baseUrl}}/room-categories
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one room category
GET {{baseUrl}}/room-categories/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create room category
POST {{baseUrl}}/room-categories
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "monthly_rent": 500,
  "if_kitchen": true,
  "category_name": "Standard"
}

###
# Update room category
PATCH {{baseUrl}}/room-categories/2
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "monthly_rent": 600,
  "category_name": "Comfort"
}

###
# Delete room category
DELETE {{baseUrl}}/room-categories/2
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# ROOM RESERVATIONS
# =========================

###
# Get all reservations
GET {{baseUrl}}/room-reservations
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one reservation
GET {{baseUrl}}/room-reservations/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create reservation
POST {{baseUrl}}/room-reservations
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "start_date_reserv": "2026-05-11",
  "end_date_reserv": "2026-06-10",
  "id_room": 4,
  "id_resident": 2
}

###
# Update reservation
PATCH {{baseUrl}}/room-reservations/1
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "end_date_reserv": "2026-05-15"
}

###
# Delete reservation
DELETE {{baseUrl}}/room-reservations/5
Authorization: Bearer {{login.response.body.$.access_token}}

###
# =========================
# EQUIPMENT
# =========================

###
# Get all equipment
GET {{baseUrl}}/equipment
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Get one equipment item
GET {{baseUrl}}/equipment/1
Authorization: Bearer {{login.response.body.$.access_token}}

###
# Create equipment
POST {{baseUrl}}/equipment
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "equipment_name": "Desk Lamp",
  "description": "LED bedside lamp",
  "id_signed_on_sticker": 1001
}

###
# Update equipment
PATCH {{baseUrl}}/equipment/1
Authorization: Bearer {{login.response.body.$.access_token}}
Content-Type: application/json

{
  "equipment_name": "LED Desk Lamp",
  "description": "LED bedside lamp",
  "id_signed_on_sticker": 1011
}

###
# Delete equipment
DELETE {{baseUrl}}/equipment/1
Authorization: Bearer {{login.response.body.$.access_token}}

# NOTES
# Admin can delete himself live and create a new account.
# Its possible to reserve the same period of time as the same person. (Maybe keep maybe not - kinda like one person took both spaces in the room)