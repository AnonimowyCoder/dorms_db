@baseUrl = http://localhost:3001
@json = Content-Type: application/json
@auth = Authorization: Bearer {{login.response.body.$.access_token}}

###
# Health check
GET {{baseUrl}}

###
# @name login
POST {{baseUrl}}/auth/login
{{json}}

{
  "email": "admin@example.com",
  "password": "password123"
}

###

###
# Get current authenticated user
GET {{baseUrl}}/auth/me
{{auth}}

###
# =========================
# USERS
# Admin only
# =========================

###
# Get all users
GET {{baseUrl}}/users
{{auth}}

###
# Get one user
GET {{baseUrl}}/users/3
{{auth}}

###
# Create user
POST {{baseUrl}}/users
{{auth}}
{{json}}

{
  "email": "manager1@example.com",
  "password": "password123",
  "role": "manager"
}

###
# Update user
PATCH {{baseUrl}}/users/3
{{auth}}
{{json}}

{
  "email": "manager1@example.com",
  "role": "manager"
}

###
# Delete user
DELETE {{baseUrl}}/users/1
{{auth}}

###
# =========================
# RESIDENTS
# Admin or Manager
# =========================

###
# Get all residents
GET {{baseUrl}}/residents
{{auth}}

###
# Get one resident
GET {{baseUrl}}/residents/1
{{auth}}

###
# Create resident
POST {{baseUrl}}/residents
{{auth}}
{{json}}

{
  "first_name": "Json",
  "last_name": "Therulo",
  "department": "Nuclear Physics"
}

###
# Update resident
PATCH {{baseUrl}}/residents/1
{{auth}}
{{json}}

{
  "department": "science"
}

###
# Delete resident
DELETE {{baseUrl}}/residents/1
{{auth}}

###
# =========================
# ROOMS
# Admin or Manager
# =========================

###
# Get all rooms
GET {{baseUrl}}/rooms
{{auth}}

###
# Get available rooms
GET {{baseUrl}}/rooms/available
{{auth}}

###
# Get one room
GET {{baseUrl}}/rooms/2
{{auth}}

###
# Create room
POST {{baseUrl}}/rooms
{{auth}}
{{json}}

{
  "room_number": 201,
  "floor_number": 1,
  "num_of_beds": 2,
  "id_category": 1
}

###
# Update room
PATCH {{baseUrl}}/rooms/1
{{auth}}
{{json}}

{
  "num_of_beds": 3
}

###
# Delete room
DELETE {{baseUrl}}/rooms/2
{{auth}}

###
# =========================
# ROOM CATEGORIES
# Read: admin or manager
# Write: admin only
# =========================

###
# Get all room categories
GET {{baseUrl}}/room-categories
{{auth}}

###
# Get one room category
GET {{baseUrl}}/room-categories/1
{{auth}}

###
# Create room category
POST {{baseUrl}}/room-categories
{{auth}}
{{json}}

{
  "monthly_rent": 500,
  "if_kitchen": true,
  "category_name": "Standard"
}

###
# Update room category
PATCH {{baseUrl}}/room-categories/2
{{auth}}
{{json}}

{
  "monthly_rent": 600,
  "category_name": "Comfort"
}

###
# Delete room category
DELETE {{baseUrl}}/room-categories/2
{{auth}}

