{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug nestjs back",
            "runtimeExecutable": "npm",
            "runtimeArgs": [ "run", "start:debug" ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug nextjs front",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [ "run", "dev" ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/frontend"
        }
    ]
}